{
  "name": "@tangent.to/proba",
  "version": "0.1.2",
  "description": "Probability distributions for JavaScript (ESM): logpdf with analytic gradients, pdf/cdf/quantile, seedable sampling. scipy.stats-validated.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "CONTRACT.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build:browser",
    "test": "vitest",
    "test:run": "vitest run",
    "test:scipy": "uv run --with scipy python3 tests_compare-to-scipy/compare_with_scipy.py",
    "build:browser": "esbuild src/index.js --bundle --platform=browser --format=esm --target=es2020 --outfile=dist/index.js --sourcemap --minify --keep-names",
    "jsr:publish": "deno publish --allow-dirty",
    "jsr:publish:dry-run": "deno publish --dry-run --allow-dirty",
    "version": "node scripts/sync-version.mjs && git add deno.json",
    "deno:check": "deno check src/index.js"
  },
  "keywords": [
    "probability",
    "distributions",
    "statistics",
    "logpdf",
    "gradients",
    "bayesian",
    "esm",
    "browser"
  ],
  "author": "Essi Parent",
  "license": "MIT",
  "homepage": "https://github.com/tangent-to/proba",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangent-to/proba"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "vitest": "^1.6.0"
  }
}
